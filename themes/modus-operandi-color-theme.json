  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#595959",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#3548cf"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#0000b0"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#531ab6"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#721045"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#005f5f"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#005e8b"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#2f3f83"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#0000b0"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#721045"
      }
    },
    {
      "scope": [
        "attribute.name",
        "entity.other.attribute-name",
        "support.type.property-name",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#005e8b"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#005f5f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#000000",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#531ab6"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ffffff",
        "background": "#a60000"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#721045",
    "class": "#005f5f",
    "interface": "#005f5f",
    "type": "#005f5f",
    "typeParameter": "#6f5500",
    "enum": "#721045",
    "enumMember": "#0000b0",
    "function": "#721045",
    "method": "#721045",
    "macro": "#a0132f",
    "variable": "#005e8b",
    "parameter": "#2f3f83",
    "property": "#005e8b",
    "label": "#a60000",
    "string": "#3548cf",
    "number": "#0000b0",
    "regexp": "#005f5f",
    "operator": "#000000",
    "keyword": "#531ab6",
    "comment": {
      "foreground": "#595959",
      "italic": true
    }
  }
}
